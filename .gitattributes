# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized
*.c text
*.cpp text
*.h text
*.hpp text
*.cmake text
*.txt text
*.md text
*.yaml text
*.yml text
*.json text
*.gitignore text
*.gitattributes text

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.rar binary
*.enc binary
*.key binary
*.pem binary
*.p12 binary
